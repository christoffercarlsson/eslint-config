{
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "extends": ["airbnb-base", "prettier"],
  "plugins": ["import", "prettier"],
  "rules": {
    "import/extensions": ["error", "always", { "ignorePackages": true }],
    "no-bitwise": "off",
    "no-restricted-syntax": "off",
    "prettier/prettier": "error"
  }
}
