{
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "extends": ["prettier", "semistandard"],
  "plugins": ["import", "prettier"],
  "rules": {
    "import/extensions": ["error", "always", { "ignorePackages": true }],
    "indent": "off",
    "no-bitwise": "off",
    "no-restricted-syntax": "off",
    "prettier/prettier": "error",
    "space-before-function-paren": "off"
  }
}
